163500398397446, 0.040579404681921005, -0.044760312885046005, 0.007789247669279575, -0.01018327847123146, 0.00581023283302784, 0.013434242457151413, 0.029158761724829674, 0.013203677721321583, -0.024977853521704674, 0.051246870309114456, 0.04005679115653038, 0.03984159603714943, 0.022211074829101562, -0.017323100939393044, -0.047311898320913315, 0.01978245936334133, 0.045098476111888885, -0.055673714727163315, 0.041870567947626114, -0.0685546025633812, -0.00929944682866335, -0.011973998509347439, -0.018383700400590897, -0.02253386564552784, -0.0278061144053936, 0.06289807707071304, -0.058809395879507065, -0.017415327951312065, 0.0031049393583089113, 0.01298079825937748, -0.03341652452945709, -0.03323207423090935, -0.03289391100406647, -0.01981320232152939, -0.018875570967793465], 'text_index': 8}]}, 'usage': {'total_tokens': 1001}, 'request_id': '3fc49c35-6a9e-959c-9d27-354845e78cc7'}
